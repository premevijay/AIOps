# Base URL of the Grafana instance the Monitoring view embeds panels from.
# The dashboard renders Grafana "d-solo" panels in an <iframe>, so Grafana must
# have anonymous viewing and embedding (allow_embedding) enabled. The repo's
# Grafana config already enables both.
# Note: Vite inlines VITE_* vars at build time, so set this before `npm run build`
# (or pass it as the VITE_GRAFANA_URL Docker build arg).
VITE_GRAFANA_URL=http://localhost:3000
