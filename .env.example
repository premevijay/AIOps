# Copy to .env (which is git-ignored) and fill in. Never commit real secrets.

# --- secret provider: "env" (lab first-run) or "cyberark" (Conjur) ---
SECRET_PROVIDER=env

# env provider — shared lab credentials (used when SECRET_PROVIDER=env)
DEVICE_USERNAME=admin
DEVICE_PASSWORD=changeme
DEVICE_ENABLE=

# --- CyberArk Conjur (used when SECRET_PROVIDER=cyberark) ---
# Generate the data key once:  docker run --rm cyberark/conjur data-key generate
CONJUR_DATA_KEY=
CONJUR_ACCOUNT=default
CONJUR_LOGIN=host/aiops/aiops-worker
CONJUR_API_KEY=

# --- execution backend: "local" (ansible-runner) or "awx" (job templates) ---
EXECUTION_BACKEND=local

# AWX (used when EXECUTION_BACKEND=awx) — see docs/setup/AWX_SETUP.md
AWX_URL=
AWX_TOKEN=
AWX_TEMPLATES=          # e.g. backup=12,health=13,compliance=14

# --- supervisor agent (LLM) ---
ANTHROPIC_API_KEY=
# Claude model id for the agent — see https://docs.claude.com/en/docs/about-claude/models
ANTHROPIC_MODEL=

# --- telemetry (monitoring capability) ---
SNMP_COMMUNITY=public
GRAFANA_ADMIN_PASSWORD=admin
# Grafana base URL the dashboard embeds (build-time, inlined by Vite)
VITE_GRAFANA_URL=http://localhost:3000

# --- change management (gated writes) ---
# Shared HMAC key between the change service and the worker. The worker refuses
# to apply any config change without a token signed by this key. Set a strong,
# random value. Generate one with:  openssl rand -hex 32
CHANGE_SIGNING_KEY=
# Require an explicit change window before a change can be applied (true/false).
REQUIRE_CHANGE_WINDOW=false

# --- platform ---
STATE_DB_PASSWORD=aiops
LOG_LEVEL=INFO
